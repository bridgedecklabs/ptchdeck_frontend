# Frontend calls this when you add real backend features (set to Render URL in Vercel)
VITE_API_URL=http://localhost:8000

# Notify Me forms (Coming Soon, CTA banners, Footer) → Sheet 1
VITE_GOOGLE_SHEETS_URL=https://script.google.com/macros/s/YOUR_NOTIFY_SCRIPT_ID/exec

# Get in Touch / Contact form → Sheet 2
VITE_GOOGLE_SHEETS_CONTACT_URL=https://script.google.com/macros/s/YOUR_CONTACT_SCRIPT_ID/exec

# Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
